# Copy this to .env and fill in your values

# PostgreSQL connection string
# Local: postgres://postgres:password@localhost:5432/integrate
# Railway: paste the connection string from your Railway Postgres service
DATABASE_URL=

# Clerk secret key (from Clerk dashboard → API Keys)
CLERK_SECRET_KEY=

# URL of the frontend app (for CORS)
CLIENT_URL=http://localhost:5173

# Set to "production" on Railway
NODE_ENV=development

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (email delivery)
RESEND_API_KEY=
RESEND_FROM_EMAIL=billing@integrateliteracy.com
RESEND_FROM_NAME=Integrate Language & Literacy

# AI Services
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
